{
  "source_repo": "https://github.com/wenyue/agents",
  "source_ref": "master",
  "mirror_delete": true,
  "ignore": [
    "__pycache__",
    "__pycache__/**",
    "**/__pycache__",
    "**/__pycache__/**",
    "*.pyc",
    "**/*.pyc"
  ],
  "retired_assets": {
    "rules": [
      "03-global-engineering-workflow.md",
      "03-global-skill-config.md"
    ],
    "skills": [
      "update-project-rules",
      "project-development-workflow",
      "project-verification"
    ],
    "agents": [
      "rename",
      "verifier"
    ]
  },
  "rules": [
    {
      "file": "00-global-rule-config.md",
      "read_when": "Starting any repository task",
      "strength": "Mandatory",
      "section": "global",
      "cursor": {
        "description": "[mandatory] Rule strength, conflict precedence, and shared config policy",
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "01-global-personality.md",
      "read_when": "Starting any repository task",
      "strength": "Default",
      "section": "global",
      "cursor": {
        "description": "[default] Agent reasoning, judgment, collaboration, and temperament",
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "02-global-response-format.md",
      "read_when": "Starting any repository task",
      "strength": "Default",
      "section": "global",
      "cursor": {
        "description": "[default] Response format and tag protocol for agent replies",
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "03-global-reasoning-workflow.md",
      "read_when": "Starting any repository task",
      "strength": "Mandatory",
      "section": "global",
      "cursor": {
        "description": "[mandatory] Objective understanding, professional judgment, action, and verification",
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "04-global-skill-config.md",
      "read_when": "Starting any repository task",
      "strength": "Mandatory",
      "section": "global",
      "cursor": {
        "description": "[mandatory] Skill and automation constraints",
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "10-base-code.md",
      "read_when": "Working with code, reviews, or implementation design",
      "strength": "Default",
      "section": "base",
      "cursor": {
        "description": "[default] Cross-language code goals for ownership, clarity, state, and boundaries",
        "globs": "**/*.{dart,cpp,c,h,hpp,cc,py,js,jsx,ts,tsx,sh}",
        "alwaysApply": false
      },
      "github": {
        "applyTo": "**/*.{dart,cpp,c,h,hpp,cc,py,js,jsx,ts,tsx,sh}"
      }
    },
    {
      "file": "11-base-cpp.md",
      "read_when": "Working with C++ files",
      "strength": "Default",
      "section": "base",
      "cursor": {
        "description": "[default] C++ style and conventions for native plugin and host code",
        "globs": "**/*.cc,**/*.h",
        "alwaysApply": false
      },
      "github": {
        "applyTo": "**/*.cc,**/*.h"
      }
    },
    {
      "file": "11-base-flutter.md",
      "read_when": "Working with Dart or Flutter code",
      "strength": "Default",
      "section": "base",
      "cursor": {
        "description": "[default] Project-neutral Dart and Flutter application defaults",
        "globs": "**/*.dart",
        "alwaysApply": false
      },
      "github": {
        "applyTo": "**/*.dart"
      }
    },
    {
      "file": "11-base-go.md",
      "read_when": "Working with Go code",
      "strength": "Default",
      "section": "base",
      "cursor": {
        "description": "[default] Go style, package boundaries, errors, testing, and concurrency",
        "globs": "**/*.go",
        "alwaysApply": false
      },
      "github": {
        "applyTo": "**/*.go"
      }
    },
    {
      "file": "12-base-arb.md",
      "read_when": "Working with ARB localization files",
      "strength": "Mandatory",
      "section": "base",
      "cursor": {
        "description": "[mandatory] ARB localization, key naming, and metadata conventions",
        "globs": "**/*.arb",
        "alwaysApply": false
      },
      "github": {
        "applyTo": "**/*.arb"
      }
    }
  ],
  "rule_blueprints": [
    {
      "file": "20-project-tools.md",
      "read_when": "Project tooling, MCP, runtime, or verification",
      "strength": "Mandatory",
      "section": "project",
      "cursor": {
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "21-project-rules.md",
      "read_when": "Project APIs, generated files, lint, or domain conventions",
      "strength": "Default",
      "section": "project",
      "cursor": {
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    },
    {
      "file": "22-project-structure.md",
      "read_when": "Making structure, module, or dependency-boundary decisions",
      "strength": "Advisory",
      "section": "project",
      "cursor": {
        "alwaysApply": true
      },
      "github": {
        "applyTo": "**"
      }
    }
  ],
  "skills": [
    {
      "name": "debug-mode"
    },
    {
      "name": "refactor-code"
    },
    {
      "name": "rename"
    },
    {
      "name": "setup-project-agents"
    },
    {
      "name": "track-worktree-time"
    },
    {
      "name": "worktree-integrate"
    },
    {
      "name": "write-comment"
    },
    {
      "name": "write-rule"
    },
    {
      "name": "write-skill"
    }
  ],
  "skill_blueprints": [
    {
      "name": "worktree-environment-setup"
    },
    {
      "name": "change-set-verification"
    }
  ],
  "agent_prompts": [
    {
      "name": "change-set-verifier",
      "description": "Normalizes and verifies a coherent completed change set, then returns semantic diagnostics to the parent agent.",
      "required_intelligence": "Medium: follow the explicit verification contract, run the required checks, preserve unrelated work, and return diagnostics without making semantic fixes. Select each platform's current balanced general-purpose model tier—the tier between the flagship/deepest model and the fastest/lightweight model—and use medium reasoning effort where supported. Prefer capability, latency, and cost balance; escalate to a flagship model only when repository evidence shows that the verification task requires deeper judgment.",
      "codex": {
        "sandbox_mode": "workspace-write"
      },
      "cursor": {
        "readonly": false
      }
    }
  ],
  "entry_files": [
    {
      "template": "AGENTS.md",
      "path": "AGENTS.md"
    }
  ],
  "config_templates": [
    {
      "path": ".codex/config.toml",
      "template": "project-config/codex.config.toml",
      "format": "toml",
      "merge": "deep-overwrite",
      "validations": [
        {
          "kind": "relative-paths-exist",
          "objects_path": "agents",
          "field": "config_file",
          "base_path": ".codex"
        }
      ]
    },
    {
      "path": ".cursor/cli.json",
      "template": "project-config/cursor.cli.json",
      "format": "json",
      "merge": "deep-overwrite"
    },
    {
      "path": ".cursor/mcp.json",
      "template": "project-config/cursor.mcp.json",
      "format": "json",
      "merge": "deep-overwrite"
    },
    {
      "path": ".github/copilot/settings.json",
      "template": "project-config/copilot.settings.json",
      "format": "jsonc",
      "merge": "deep-overwrite"
    },
    {
      "path": ".mcp.json",
      "template": "project-config/copilot.mcp.json",
      "format": "json",
      "merge": "deep-overwrite"
    },
    {
      "path": ".github/mcp.json",
      "template": "project-config/copilot.mcp.json",
      "format": "json",
      "merge": "deep-overwrite"
    },
    {
      "path": ".vscode/mcp.json",
      "template": "project-config/vscode.mcp.json",
      "format": "json",
      "merge": "deep-overwrite"
    },
    {
      "path": ".codex/hooks.json",
      "template": "project-config/codex.hooks.json",
      "format": "json",
      "merge": "deep-overwrite",
      "list_merges": [
        {
          "path": "hooks.SessionStart",
          "owned_marker": "setup-project-agents"
        }
      ]
    },
    {
      "path": ".cursor/hooks.json",
      "template": "project-config/cursor.hooks.json",
      "format": "json",
      "merge": "deep-overwrite",
      "list_merges": [
        {
          "path": "hooks.sessionStart",
          "owned_marker": "setup-project-agents"
        }
      ]
    },
    {
      "path": ".github/hooks/project-agent-tool-check.json",
      "template": "project-config/copilot.tool-check.hooks.json",
      "format": "json",
      "merge": "deep-overwrite"
    }
  ],
  "platforms": {
    "agent_defaults": {
      "codex": {
        "sandbox_mode": "workspace-write"
      },
      "cursor": {
        "readonly": false
      }
    },
    "rule_wrappers": [
      {
        "template": "rule_wrapper.cursor.mdc",
        "path": ".cursor/rules/{{rule.name}}.mdc"
      },
      {
        "template": "rule_wrapper.github.instructions.md",
        "path": ".github/instructions/{{rule.name}}.instructions.md"
      }
    ],
    "agent_wrappers": [
      {
        "template": "agent_wrapper.cursor.md",
        "path": ".cursor/agents/{{agent.name}}.md"
      },
      {
        "template": "agent_wrapper.codex.toml",
        "path": ".codex/agents/{{agent.name}}.toml"
      },
      {
        "template": "agent_wrapper.github.agent.md",
        "path": ".github/agents/{{agent.name}}.agent.md"
      }
    ]
  }
}
